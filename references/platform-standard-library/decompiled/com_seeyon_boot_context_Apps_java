    public static boolean ignorePermissionCheck(String entityFullName) {
        Object set = Apps.getThreadContext("IGNORE_PERMISSION_KEY");
        if (null == set) {
            return false;
        }
        HashSet ignoreSet = (HashSet)set;
        if (ignoreSet.isEmpty()) {
            return true;
        }
        return ignoreSet.contains(entityFullName);
    }

    public static String ignorePermissionKey() {
        Object set = Apps.getThreadContext("IGNORE_PERMISSION_KEY");
        if (null == set) {
            return "false";
