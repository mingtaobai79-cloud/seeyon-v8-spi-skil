    public static Map<String, AppInfo> getAllAppInfo() {
        if (onlineApps.isEmpty()) {
            Map<String, AppInfo> map = onlineApps;
            synchronized (map) {
                if (onlineApps.isEmpty()) {
                    try {
                        if (!monolithic && !Apps.isElastic()) {
                            AppInfo appInfo = new AppInfo();
                            appInfo.setAppCaption(Apps.getAppCaption());
                            appInfo.setAppName(Apps.getAppName());
                            appInfo.setDescription(Apps.getAppDescription());
                            appInfo.setOwner(Apps.getAppOwner());
                            appInfo.setUdcApp(Apps.isUdcApp());
                            appInfo.setBasePackage(Apps.getBasePackage());
                            appInfo.setBuildInfo(Apps.getBuildInfo());
                            onlineApps.put(appInfo.getAppName(), appInfo);
                        } else {
                            String assembleJarName = "-assemble-resource";
                            Set classes = BeanReflections.getTypesAnnotatedWith(BootApp.class);
                            for (Class clazz : classes) {
                                BootApp bootApp = clazz.getAnnotation(BootApp.class);
                                if ("a9".equals(bootApp.name())) continue;
                                AppInfo appInfo = new AppInfo();
                                appInfo.setAppCaption(bootApp.caption());
                                appInfo.setAppName(bootApp.name());
                                appInfo.setDescription(bootApp.description());
                                appInfo.setOwner(bootApp.owner());
                                appInfo.setUdcApp(bootApp.udcApp());
                                appInfo.setBasePackage(Apps.getBasePackage());
                                org.springframework.core.io.Resource resource = ResourceUtils.getAllClassPathResource((String)("META-INF/maven/**/" + appInfo.getAppName() + assembleJarName + "/**/pom.properties"));
                                BuildInfo buildInfo = Apps.getBuildInfo(resource);
                                appInfo.setBuildInfo(buildInfo);
                                log.info("\u52a0\u8f7d\u5e94\u7528:{},INFO:{}", (Object)bootApp.name(), (Object)JsonUtils.toJson((Object)appInfo));
                                onlineApps.put(appInfo.getAppName(), appInfo);
                            }
                        }
                    }
                    catch (Exception e) {
                        log.error("", (Throwable)e);
                    }
                }
            }
        }
        return onlineApps;
    }

    public static Integer getParametersLimit() {
        Integer limit;
        if (parameterLimit != null && parameterLimit > 0) {
            return parameterLimit;
        }
        if (null != Apps.getEnvironment().getProperty("seeyon.mybatis.parametersLimit") && null != (limit = Integer.valueOf(Integer.parseInt(Apps.getEnvironment().getProperty("seeyon.mybatis.parametersLimit")))) && limit > 0) {
            parameterLimit = limit;
            return parameterLimit;
        }
        if (Apps.getDatabaseType() == DatabaseType.dm7 || Apps.getDatabaseType() == DatabaseType.dm8 || Apps.getDatabaseType() == DatabaseType.sqlserver || Apps.getDatabaseType() == DatabaseType.kingbasev8 || Apps.getDatabaseType() == DatabaseType.oracle || Apps.getDatabaseType() == DatabaseType.tidb) {
            parameterLimit = 2048;
            return parameterLimit;
        }
        if (Apps.getDatabaseType() == DatabaseType.postgresql) {
            parameterLimit = 512;
            return parameterLimit;
        }
        parameterLimit = FINAL_PARAMETERS_LIMIT;
        return parameterLimit;
    }

    public static Map<String, BuildInfo> depends() {
        LinkedHashMap<String, BuildInfo> result = new LinkedHashMap<String, BuildInfo>();
        if (!jarInfoMap.isEmpty()) {
            result.putAll(currentAppJarInfoMap);
            result.putAll(jarInfoMap);
            return result;
        }
        org.springframework.core.io.Resource[] resources = ResourceUtils.getAllClassPathResources((String)"META-INF/maven/com.seeyon/**/pom.properties");
        if (resources != null) {
            for (org.springframework.core.io.Resource re : resources) {
                try {
                    BuildInfo buildInfo = Apps.getBuildInfo(re);
                    if (buildInfo == null) continue;
                    if (buildInfo.getArtifactId().contains(Apps.getAppName())) {
                        currentAppJarInfoMap.put(buildInfo.getArtifactId(), buildInfo);
                        continue;
                    }
                    jarInfoMap.put(buildInfo.getArtifactId(), buildInfo);
                }
                catch (Exception exception) {
                    // empty catch block
                }
            }
        }
        result.putAll(currentAppJarInfoMap);
        result.putAll(jarInfoMap);
        return result;
    }

