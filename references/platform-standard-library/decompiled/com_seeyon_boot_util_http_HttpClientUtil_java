    private static OutputStream fmt2Stream(HttpResponse resp, OutputStream out) throws HttpProcessException {
        try {
            resp.getEntity().writeTo(out);
            EntityUtils.consume((HttpEntity)resp.getEntity());
        }
        catch (IOException e) {
            throw new HttpProcessException("", (Exception)e);
        }
        finally {
            HttpClientUtil.close(resp);
        }
        return out;
    }

    private static HttpRequestBase getRequest(HttpConfig config) {
        HttpGet request = null;
        switch (config.method().getCode()) {
            case 0: {
                request = new HttpGet(config.url());
                break;
            }
            case 3: {
                request = new HttpPut(config.url());
                break;
            }
            case 4: {
                request = new HttpDelete(config.url());
                break;
            }
            default: {
                request = new HttpPost(config.url());
            }
        }
        if (request != null && config.httpVersion() != null) {
            request.setProtocolVersion((ProtocolVersion)config.httpVersion().httpVersion());
        }
        return request;
    }

    private static void close(HttpResponse resp) {
        try {
            if (resp == null) {
                return;
            }
            if (CloseableHttpResponse.class.isAssignableFrom(resp.getClass())) {
                ((CloseableHttpResponse)resp).close();
            }
        }
        catch (IOException e) {
            log.error("", (Throwable)e);
        }
    }

